# This file is for reference only. The deploy tool GENERATES a real .env (with
# auto-created secrets) inside the chosen terraform/<cloud>/ directory.
#
# These are the values that end up on the server in /opt/enlight/.env:

NODE_ENV=production
PORT=3000

# Database + queue point at the docker-compose service names
DATABASE_URL=postgresql://enlight:<generated-password>@postgres:5432/enlight
REDIS_URL=redis://redis:6379
POSTGRES_USER=enlight
POSTGRES_PASSWORD=<generated-password>
POSTGRES_DB=enlight

# Secrets — auto-generated by the deploy tool
JWT_SECRET=<generated>
SESSION_SECRET=<generated>
SECRETS_ENCRYPTION_KEY=<generated 64-hex>

# AI (platform also selectable in-app under Settings → AI Keys)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# VOYAGE_API_KEY=pa-...
EMBEDDING_PROVIDER=voyage

# Public URLs (set to your domain for correct email/portal/SSO links)
# API_URL=https://your-domain
# WEB_URL=https://your-domain

LICENSE_ENFORCEMENT=false
